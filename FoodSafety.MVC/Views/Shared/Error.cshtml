@model FoodSafety.MVC.Models.ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="text-center mt-5">
    <div class="mb-4">
        <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: #dc3545;"></i>
    </div>
    <h1 class="display-4 text-danger">Oops! Something went wrong.</h1>
    <p class="lead">We're sorry — an unexpected error occurred. Our team has been notified.</p>
    <p class="text-muted">Please try again or go back to the home page.</p>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
            Go to Home
        </a>
        <a href="javascript:history.back()" class="btn btn-secondary">
            Go Back
        </a>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="mt-4 text-muted small">
            <p>Request ID: <code>@Model.RequestId</code></p>
        </div>
    }
</div>