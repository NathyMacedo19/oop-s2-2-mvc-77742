@model FoodSafety.Domain.Followup
@{
    ViewData["Title"] = "Create Follow-Up";
}

<h1>Create Follow-Up</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="InspectionId" class="form-label">Inspection</label>
        <select asp-for="InspectionId" class="form-control" asp-items="@(ViewBag.Inspections as SelectList)">
            <option value="">-- Select Inspection --</option>
        </select>
        <span asp-validation-for="InspectionId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="date" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
