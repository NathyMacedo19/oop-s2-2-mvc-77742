@{
    ViewData["Title"] = "Delete Follow-Up";
}

<h1>Delete Follow-Up</h1>
<p class="text-danger">Are you sure you want to delete this follow-up?</p>

<dl class="row">
    <dt class="col-sm-3">Inspection ID</dt>
    <dd class="col-sm-9">@Model.InspectionId</dd>
    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
