@model FoodSafety.MVC.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-12">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="town" class="form-label">Filter by Town</label>
                <select name="town" id="town" class="form-select" asp-items="@(new SelectList(Model.Towns, Model.SelectedTown))">
                    <option value="">All Towns</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="riskRating" class="form-label">Filter by Risk Rating</label>
                <select name="riskRating" id="riskRating" class="form-select" asp-items="@(new SelectList(Model.RiskRatings, Model.SelectedRiskRating))">
                    <option value="">All Risk Ratings</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">Apply Filters</button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Inspections This Month</div>
            <div class="card-body">
                <h2 class="card-title">@Model.InspectionsThisMonth</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-header">Failed Inspections This Month</div>
            <div class="card-body">
                <h2 class="card-title">@Model.FailedInspectionsThisMonth</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning mb-3">
            <div class="card-header">Overdue Follow-ups</div>
            <div class="card-body">
                <h2 class="card-title">@Model.OverdueFollowUps</h2>
            </div>
        </div>
    </div>
</div>
